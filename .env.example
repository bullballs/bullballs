# =============================================================================
# BULL BALLS — Environment Config
# Copy this file to `.env` and fill in your values before launch.
# Restart `npm run dev` and `npm run server` after changes.
# =============================================================================

# --- Token / Links (frontend) ---
# Solana contract address shown on landing + used for buy/chart links
VITE_TOKEN_CA=BAlLS7x1pUXs2U8hQW5Yd7S13v1kPnQZ9Mpump
VITE_TOKEN_SYMBOL=$BALLS

# Override buy/chart URLs (optional — auto-built from CA if left blank)
# VITE_BUY_URL=https://pump.fun/coin/YOUR_CA
# VITE_DEXSCREENER_URL=https://dexscreener.com/solana/YOUR_CA

# Social links (footer)
VITE_TWITTER_URL=https://x.com/Bull__Balls
# VITE_TELEGRAM_URL=https://t.me/your_channel

# --- Jupiter price feed (frontend — vault SOL quote) ---
# Get a free key at https://portal.jup.ag/
# VITE_JUP_API_KEY=your-jupiter-api-key
# VITE_JUP_PRICE_URL=https://api.jup.ag/price/v3?ids=So11111111111111111111111111111111111111112

# --- Solana RPC (frontend — reserved for wallet connect later) ---
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com

# --- Reward / withdraw API (frontend) ---
# Dev: Vite proxies /api → localhost:3001
VITE_REWARD_API_URL=/api
# Production (Railway): full API URL, e.g. https://balls-reward-api.up.railway.app/api
# VITE_REWARD_API_URL=https://your-service.up.railway.app/api
# Set true to skip backend (local UI testing only)
VITE_REWARD_DEMO_MODE=false

# --- Reward API server (backend — NOT exposed to browser) ---
# Railway injects PORT automatically — do not set REWARD_API_PORT there
REWARD_API_PORT=3001
REWARD_ADMIN_KEY=change-me-before-launch
# Comma-separated frontend URLs for CORS (required in production)
# ALLOWED_ORIGINS=https://your-game.vercel.app,https://www.bullballs.xyz
# Persistent claims storage — mount Railway Volume at /data and set:
# CLAIMS_DATA_DIR=/data
